# ============================================================
# ZVELO AGENT — Environment Variables
# Kopieer dit bestand naar .env en vul je API keys in
# Als een key ontbreekt, draait de app in simulatiemodus
# ============================================================

# Server
PORT=3001
BACKEND_URL=http://localhost:3001

# Anthropic Claude API
# Aanvragen op: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI DALL-E API
# Aanvragen op: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Smartmockups API
# Aanvragen op: https://smartmockups.com/api
SMARTMOCKUPS_API_KEY=

# Etsy API
# Aanvragen op: https://www.etsy.com/developers/documentation
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=
ETSY_REDIRECT_URI=http://localhost:3001/auth/etsy/callback

# Email notificaties (optioneel — Gmail voorbeeld)
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=

# Agent instellingen
AGENT_CRON_SCHEDULE=0 8 * * *
AGENT_CONCEPTS_PER_DAY=3
DEFAULT_NICHE=Minimalist Wall Art Printables
